# SEO Test Instance Environment Variables
# This file is used by docker-compose.seo-test.yml
# Fill in your API keys below — the database is local (separate from production)

# =============================================================================
# Content Mode — THIS IS THE KEY SETTING
# =============================================================================
CONTENT_MODE=lorem

# =============================================================================
# Database — Points to local docker PostgreSQL (NOT Neon production)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@db:5432/onboarding

# =============================================================================
# Auth — Disabled for local SEO testing
# =============================================================================
AUTH_REQUIRED=false

# =============================================================================
# API Keys — Fill these in with your keys
# =============================================================================

# Anthropic API — Required for content generation (even in lorem mode)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# PageOptimizer Pro — Required for POP briefs
POP_API_KEY=your-pop-api-key-here
USE_POP_CONTENT_BRIEF=true
USE_POP_SCORING=false
# Set to true for development without burning POP credits
POP_USE_MOCK=false

# DataForSEO — Required for keyword research
DATAFORSEO_API_LOGIN=your-login-here
DATAFORSEO_API_PASSWORD=your-password-here

# Perplexity — Optional (brand research)
PERPLEXITY_API_KEY=

# =============================================================================
# Application
# =============================================================================
APP_NAME=Grove SEO Test
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# Redis / S3 — Local services via docker-compose
# =============================================================================
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://localstack:4566
S3_BUCKET=onboarding-files
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_REGION=us-east-1
